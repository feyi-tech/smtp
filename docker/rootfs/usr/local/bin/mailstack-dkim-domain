#!/usr/bin/env bash
set -euo pipefail

DOMAIN=${1:-}
SELECTOR=${2:-default}

if [ -z "$DOMAIN" ]; then
  echo "Usage: mailstack-dkim-domain example.com [selector]"
  exit 1
fi

case "$DOMAIN" in
  *[!a-zA-Z0-9.-]*|.*|*..*|*-|*.)
    echo "Invalid domain: $DOMAIN"
    exit 1
    ;;
esac

KEY_DIR="/etc/opendkim/keys/$DOMAIN"
install -d -m 750 -o opendkim -g opendkim "$KEY_DIR"
CHANGED=0

ensure_trusted_host() {
  local host=$1
  if ! grep -Fxq "$host" /etc/opendkim/trusted.hosts 2>/dev/null; then
    echo "$host" >> /etc/opendkim/trusted.hosts
    CHANGED=1
  fi
}

if [ ! -f "$KEY_DIR/$SELECTOR.private" ]; then
  opendkim-genkey -D "$KEY_DIR" -d "$DOMAIN" -s "$SELECTOR" -b 2048
  chown -R opendkim:opendkim "$KEY_DIR"
  chmod 600 "$KEY_DIR/$SELECTOR.private"
  chmod 644 "$KEY_DIR/$SELECTOR.txt"
  CHANGED=1
fi

KEY_LINE="$SELECTOR._domainkey.$DOMAIN $DOMAIN:$SELECTOR:$KEY_DIR/$SELECTOR.private"
if ! grep -Fqx "$KEY_LINE" /etc/opendkim/key.table 2>/dev/null; then
  echo "$KEY_LINE" >> /etc/opendkim/key.table
  CHANGED=1
fi

SIGNING_LINE="*@$DOMAIN $SELECTOR._domainkey.$DOMAIN"
if ! grep -Fqx "$SIGNING_LINE" /etc/opendkim/signing.table 2>/dev/null; then
  echo "$SIGNING_LINE" >> /etc/opendkim/signing.table
  CHANGED=1
fi

ensure_trusted_host "127.0.0.1"
ensure_trusted_host "::1"
ensure_trusted_host "localhost"
ensure_trusted_host "$DOMAIN"

if [ "$CHANGED" -eq 1 ]; then
  supervisorctl restart opendkim >/dev/null 2>&1 || true
fi

echo "$KEY_DIR/$SELECTOR.txt"
